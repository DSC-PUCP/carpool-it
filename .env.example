# Client-visible variables (safe to expose in browser)
VITE_SUPABASE_URL=http://127.0.0.1:55421
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SERVER_URL=http://localhost:5173

# Server-only variables (do not expose)
# Use Cloudflare secrets for deployed environments:
# wrangler secret put SUPABASE_ANON
SUPABASE_ANON=

# Optional server variable
SERVER_URL=

# Firebase configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=